{
    "plugins": [
        "prettier-plugin-tailwindcss"
    ],
    "tailwindAttributes": [
        "className"
    ],
    "arrowParens": "always",
    "bracketSpacing": true,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 4,
    "useTabs": false,
    "vueIndentScriptAndStyle": false,
    "printWidth": 100,
    "proseWrap": "preserve",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "requirePragma": false,
    "embeddedLanguageFormatting": "auto"
}